# ============================================================
# Database
# ============================================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shopify_sync"

# ============================================================
# Shopify (optional — can be configured via the dashboard UI instead)
# ============================================================
# SHOPIFY_SHOP_DOMAIN="your-store.myshopify.com"
# SHOPIFY_ADMIN_API_TOKEN="shpat_xxxxxxxxxxxxxxxxxxxx"
# SHOPIFY_WEBHOOK_SECRET="your-webhook-hmac-signing-secret"
SHOPIFY_API_VERSION="2024-01"

# ============================================================
# Store connection encryption (required — 32 random bytes as 64 hex chars)
# Generate with: openssl rand -hex 32
# ============================================================
STORE_ENCRYPTION_KEY="your-64-hex-char-encryption-key"

# Public URL of this API service (used to register Shopify webhooks)
API_PUBLIC_URL="https://api.your-domain.railway.app"

# ============================================================
# Temporal
# Production (Temporal Cloud) — use mTLS certs:
# ============================================================
TEMPORAL_ADDRESS="your-namespace.tmprl.cloud:7233"
TEMPORAL_NAMESPACE="your-namespace.accountid"
TEMPORAL_TASK_QUEUE="shopify-order-sync"
TEMPORAL_TLS_CERT="base64-encoded-client-cert"
TEMPORAL_TLS_KEY="base64-encoded-client-key"

# Local dev — set this to skip TLS:
TEMPORAL_TLS_DISABLED="true"
# TEMPORAL_ADDRESS="localhost:7233"
# TEMPORAL_NAMESPACE="default"

# ============================================================
# API Auth (x-api-key header for /api/* routes)
# ============================================================
API_KEY="your-secret-api-key-min-32-chars"

# ============================================================
# Dashboard Auth
# ============================================================
DASHBOARD_PASSWORD="your-secure-dashboard-password"
SESSION_SECRET="random-32-char-string-for-cookie-signing"

# ============================================================
# Service URLs
# ============================================================
# Public API URL (used by Next.js client-side fetches)
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Internal API URL (used by Next.js server-side fetches in production)
INTERNAL_API_URL="http://localhost:3001"

# ============================================================
# Server
# ============================================================
PORT="3001"
NODE_ENV="development"
LOG_LEVEL="info"
